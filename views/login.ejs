<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Login</title>

<style>
body{
margin:0;
height:100vh;
display:flex;
justify-content:center;
align-items:center;
background:#f4f7fb;
font-family:Arial;
}

.login-box{
width:320px;
background:white;
padding:35px;
border-radius:10px;
box-shadow:0 5px 20px rgba(0,0,0,0.08);
}

.login-box h2{
text-align:center;
margin-bottom:25px;
color:#2563eb;
}

.login-box input{
width:100%;
padding:10px;
margin-bottom:15px;
border:1px solid #ddd;
border-radius:6px;
}

.login-box button{
width:100%;
padding:10px;
background:#2563eb;
border:none;
border-radius:6px;
color:white;
cursor:pointer;
}
</style>

</head>

<body>

<div class="login-box">

<h2>HR Login</h2>

<form action="/login" method="POST">

<input type="text" name="employee_code" placeholder="Employee Code" required>

<input type="password" name="password" placeholder="Password" required>

<button type="submit">Login</button>

</form>

</div>

</body>
</html>