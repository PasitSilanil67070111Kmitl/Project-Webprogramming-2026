<style>
    /* Admin */
.role-1{
    background:#ff4d4f;
    color:white;
}
/* Manager */
.role-2{
    background:#1890ff;
    color:white;
}
/* Staff */
.role-3{
    background:#52c41a;
    color:white;
}
</style>

<div class="head-container">
    <i class="bx bx-spanner"></i>
    <h2>จัดการสิทธิ์การเข้าถึงของพนักงาน</h2>
</div>
<div class="create-user-box">
    <h3>สร้างบัญชีสำหรับ พนักงาน</h3>

    <form action="/admin/create-user" method="POST" class="create-user-form">

        <div class="form-group">
            <label>เลือกพนักงาน</label>
            <select name="employee_id" required>
                <option value="">-- เลือกพนักงาน --</option>
                <% employees.forEach(emp=> { %>
                    <option value="<%= emp.employee_id %>">
                        <%= emp.employee_code %> - <%= emp.first_name %>
                                <%= emp.last_name %>
                    </option>
                    <% }) %>
            </select>
        </div>
        <div class="form-group">
            <label>บทบาท</label>
            <select name="role_id" required>
                <% roles.forEach(role=> { %>
                    <option value="<%= role.role_id %>">
                        <%= role.role_name %>
                    </option>
                    <% }) %>
            </select>
        </div>

        <button type="submit" class="create-btn">
            <i class="bx bx-user-plus"></i>
            สร้างบัญชี
        </button>

    </form>
</div>
<br>
<div class="main-container">
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Employee Code</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Current Role</th>
                    <th>Change Role</th>
                    <th>Delete</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(user=> { %>
                    <tr>
                        <td>
                            <%= user.employee_code %>
                        </td>
                        <td>
                            <%= user.first_name %>
                                <%= user.last_name %>
                        </td>
                        <td>
                            <%= user.email %>
                        </td>
                        <td>
                            <span class="badge role-<%= user.role_id %>">
                                <%= user.role_name %>
                            </span>
                        </td>
                        <td>
                            <form action="/admin/update-role" method="POST">
                                <input type="hidden" name="user_id" value="<%= user.user_id %>">
                                <select name="role_id">
                                    <% roles.forEach(role=> { %>
                                        <option value="<%= role.role_id %>" <%=user.role_id===role.role_id ? 'selected'
                                            : '' %>>
                                            <%= role.role_name %>
                                        </option>
                                        <% }) %>
                                </select>
                                <button type="submit">แก้ไขสิทธิ์</button>
                            </form>
                        </td>
                        <td>
                            <form action="/admin/delete-user" method="POST"
                                onsubmit="return confirm('Are you sure you want to delete this user?');">
                                <input type="hidden" name="user_id" value="<%= user.user_id %>">
                                <button type="submit" class="delete-btn">
                                    <i class="bx bx-trash"></i>
                                    <span>ลบบัญชี</span>
                                </button>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
            </tbody>
        </table>
    </div>
</div>